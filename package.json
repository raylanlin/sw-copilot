{
  "name": "sw-copilot",
  "version": "0.1.0",
  "description": "开源 SolidWorks AI 自动化助手 — 自由选择任意 AI 后端",
  "main": "dist/main/main/index.js",
  "author": "SW Copilot Contributors",
  "license": "MIT",
  "scripts": {
    "dev": "concurrently -k -n main,preload,renderer,electron -c blue,cyan,magenta,green \"npm:dev:main\" \"npm:dev:preload\" \"npm:dev:renderer\" \"npm:dev:electron\"",
    "dev:main": "tsc -w -p tsconfig.main.json",
    "dev:preload": "tsc -w -p tsconfig.preload.json",
    "dev:renderer": "vite",
    "dev:electron": "wait-on tcp:5173 && wait-on dist/main/main/index.js && cross-env NODE_ENV=development electron .",
    "build:main": "tsc -p tsconfig.main.json",
    "build:preload": "tsc -p tsconfig.preload.json",
    "build:renderer": "vite build",
    "build": "npm run build:main && npm run build:preload && npm run build:renderer",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder",
    "typecheck": "tsc -p tsconfig.main.json --noEmit && tsc -p tsconfig.preload.json --noEmit && tsc -p tsconfig.renderer.json --noEmit",
    "test": "npm run build:main && node --test tests/",
    "lint": "eslint src/ --ext .ts,.tsx",
    "format": "prettier --write src/",
    "clean": "rimraf dist release"
  },
  "dependencies": {
    "electron-store": "^8.2.0",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.19.39",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@types/uuid": "^9.0.8",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "@vitejs/plugin-react": "^4.2.0",
    "concurrently": "^8.2.0",
    "cross-env": "^7.0.3",
    "electron": "^28.3.3",
    "electron-builder": "^24.9.0",
    "eslint": "^8.55.0",
    "prettier": "^3.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "rimraf": "^5.0.5",
    "typescript": "5.3",
    "vite": "^5.0.0",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.swcopilot.app",
    "productName": "SW Copilot",
    "directories": {
      "output": "release"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "squirrel"
        }
      ],
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": true,
      "allowToChangeInstallationDirectory": false
    },
    "squirrelWindows": {},
    "publish": {
      "provider": "github",
      "owner": "raylanlin",
      "repo": "sw-copilot"
    },
    "files": [
      "dist/**/*",
      "assets/**/*",
      "package.json"
    ]
  }
}